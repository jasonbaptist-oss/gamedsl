world {
  grid_size: 50x50
  duration: 600s
}

player "Mage" {
  health: 80
  controls {
    up: W
    down: S
    left: A
    right: D
  }
}

ability "Fireball" {
  type: active
  damage: 25
  range: 10
  shape: directional
  key: SPACE
}

monster "Goblin" {
  health: 30
  movement: towards "Mage"
  count: 5
  position: 10, 10
}

assign "Mage" abilities ["Fireball"]

obstacle "Wall" {
  position: 20, 20
  size: 5x1
}

win_condition {
  kill_monsters: monster_count("Goblin") == 0 and not (player_health("Mage") < 10)
}
